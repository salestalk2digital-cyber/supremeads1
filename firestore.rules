rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net (default-deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Explicitly allowed collections for application CMS and Enquiries
    match /enquiries/{document} {
      allow read, write: if true;
    }

    match /system/{document} {
      allow read, write: if true;
    }

    match /case_studies/{document} {
      allow read, write: if true;
    }

    match /client_logos/{document} {
      allow read, write: if true;
    }

    match /gallery_items/{document} {
      allow read, write: if true;
    }

    match /testimonials/{document} {
      allow read, write: if true;
    }
  }
}
